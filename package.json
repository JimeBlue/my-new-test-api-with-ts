{
  "name": "my-new-test-api-with-ts",
 "version": "1.0.0",
    "main": "src/server.ts",
    "type": "module",
    "scripts": {
        "dev": "node --watch --env-file=.env --conditions development src/server.ts",
        "prebuild": "rm -rf dist",
        "build": "tsc",
        "prestart": "npm run build",
        "start": "node --env-file=.env dist/server.js"
    },
    "imports": {
        "#utils": {
            "development": "./src/utils/index.ts",
            "default": "./dist/utils/index.js"
        }
    },
    "devDependencies": {
        "@types/node": "^25.5.0",
        "typescript": "^6.0.2"
    }
    
}
